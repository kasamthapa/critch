// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  username String
  email String @unique
  password String
  bio String
  avatarURL String
  reputationScore Decimal @db.Decimal(10,2) @default(0)
  created_at DateTime @default(now()) @db.Timestamptz
  projects Project[]
  reviews Review[]
  reviewCount Int @default(0)
  comments Comment[]
}
model Project{
  id Int @id @default(autoincrement())
  title String
  description String
  liveURL String
  githubURL String
  screenshotURL String
  screenshotPublicId String
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz
  user User @relation(fields: [userId],references: [id],onDelete: Cascade)
  userId Int
  reviews Review[]
  avgRating Decimal @db.Decimal(2,1) @default(0)
  tags ProjectTag[]
  comments Comment[]
}
model Tag{
  id Int @id @default(autoincrement())
  name String @unique
  projects ProjectTag[]
}
//Bridge or Join table for Project and Tag table to create many to many relation
model ProjectTag{
  projectId Int
  tagId Int 
  project Project @relation(fields: [projectId],references: [id],onDelete: Cascade)
  tag Tag @relation(fields: [tagId],references: [id],onDelete: Cascade)
  @@id([projectId,tagId]) /*Composite Primary key for this table */
}

model Review{
  id Int @id @default(autoincrement())
  codeQuality Decimal @db.Decimal(2,1) @default(0)
  uiDesign Decimal @db.Decimal(2,1) @default(0)
  ideaScore Decimal @db.Decimal(2,1) @default(0)
  documentation Decimal @db.Decimal(2,1) @default(0)
  comment String
  avgReview Decimal @db.Decimal(2,1) @default(0)
  created_at DateTime @default(now()) @db.Timestamptz
  user User @relation(fields: [userId],references: [id])
  userId Int
  project Project @relation(fields: [projectId],references: [id],onDelete: Cascade)
  projectId Int
}
model Comment{
  id Int @id @default(autoincrement())
  content String
  user User @relation(fields: [userId],references: [id])
  userId Int
  project Project @relation(fields: [projectId],references: [id],onDelete: Cascade)
  projectId Int
  //Defining Self-relation for comments
  parentId Int?
  parent Comment? @relation("CommentReplies",fields: [parentId],references: [id])
  replies Comment[] @relation("CommentReplies")

}

model RefreshToken{
  id Int @id @default(autoincrement())
  user_id Int
  token  String @unique
  created_at DateTime @default(now()) @db.Timestamptz
  expires_at DateTime  @db.Timestamptz
}